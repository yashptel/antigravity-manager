# Required: API key used for all AI request authentication
API_KEY=sk-your-api-key-here

# Optional: Separate password for web dashboard login.
# If set, only WEB_PASSWORD can log in to the UI (more secure).
# If unset, API_KEY is used for both API calls and web login.
WEB_PASSWORD=

# Optional: Max request body size in bytes (default 100MB)
ABV_MAX_BODY_SIZE=104857600
